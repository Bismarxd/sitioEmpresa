---
import ProfileCard from "./Home/ProfileCard.astro";
---

<section class="services-section">
  <!-- Background -->
  <div class="services-bg">
    <div class="services-orb"></div>
    <div class="services-grid"></div>
  </div>

  <div class="services-inner">
    <!-- Section header -->
    <div class="services-header">
      <span class="section-label">Qué hacemos</span>
      <h2 class="services-title">
        Servicios que<br />
        <span class="gradient-text">ofrecemos</span>
      </h2>
      <p class="services-description">
        Tecnología moderna adaptada a las necesidades reales de tu negocio.
      </p>
    </div>

    <!-- Cards -->
    <ProfileCard />
  </div>
</section>

<style>
  .services-section {
    position: relative;
    padding: 6rem 1.5rem;
    overflow: hidden;
    background: var(--color-bg-2);
  }

  .services-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .services-orb {
    position: absolute;
    width: 50%;
    aspect-ratio: 1;
    top: -20%;
    left: -10%;
    background: radial-gradient(
      circle,
      rgba(168, 85, 247, 0.12),
      transparent 70%
    );
    filter: blur(60px);
  }

  .services-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  .services-inner {
    position: relative;
    z-index: 10;
    max-width: 1280px;
    margin: 0 auto;
  }

  .services-header {
    max-width: 520px;
    margin-bottom: 3rem;
  }

  .services-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .services-description {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
</style>
