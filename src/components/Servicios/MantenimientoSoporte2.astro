---
const servicios = [
  {
    titulo: "Actualizaciones periódicas",
    descripcion:
      "Mantén tu sitio siempre seguro y actualizado con las últimas versiones.",
  },
  {
    titulo: "Monitoreo 24/7",
    descripcion:
      "Vigila que tu sitio esté siempre en línea y funcionando sin interrupciones.",
  },
  {
    titulo: "Backup automático",
    descripcion:
      "Copias de seguridad frecuentes para proteger tus datos y restaurar rápido.",
  },
  {
    titulo: "Optimización de rendimiento",
    descripcion:
      "Mejora la velocidad y experiencia de tus usuarios en todo momento.",
  },
  {
    titulo: "Seguridad reforzada",
    descripcion: "Protege tu web contra ataques y accesos no autorizados.",
  },
  {
    titulo: "Soporte técnico rápido",
    descripcion: "Asistencia inmediata para resolver errores y dudas.",
  },
  {
    titulo: "Adaptación a dispositivos",
    descripcion:
      "Tu sitio funcionará y se verá perfecto en móviles, tablets y PCs.",
  },
  {
    titulo: "Asesoría continua",
    descripcion: "Te ayudamos a planificar mejoras que impulsen tu negocio.",
  },
];
---

<div class="relative min-h-screen">
  <!-- Fondo -->
  <div class="absolute inset-0 bg-white dark:bg-gray-950 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.2] dark:opacity-[0.15]">
      <svg
        width="100%"
        height="100%"
        viewBox="0 0 1200 600"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M0,100 C150,50 350,150 500,100 C650,50 850,150 1000,100 C1150,50 1350,150 1500,100 V600 H0 Z"
          fill="rgba(59, 130, 246, 0.2)"
          class="dark:fill-blue-500/10"></path>
        <path
          d="M0,200 C150,150 350,250 500,200 C650,150 850,250 1000,200 C1150,150 1350,250 1500,200 V600 H0 Z"
          fill="rgba(139, 92, 246, 0.2)"
          class="dark:fill-purple-500/10"></path>
        <path
          d="M0,300 C150,250 350,350 500,300 C650,250 850,350 1000,300 C1150,250 1350,350 1500,300 V600 H0 Z"
          fill="rgba(236, 72, 153, 0.2)"
          class="dark:fill-pink-500/10"></path>
      </svg>
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-b from-white via-white/0 to-white dark:from-gray-950 dark:via-gray-950/0 dark:to-gray-950"
    >
    </div>
  </div>
  <!-- Contenido -->
  <section class="py-16 relative">
    <div class="container mx-auto px-4">
    
      <div class="grid gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        {
          servicios.map(({ titulo, descripcion }) => (
            <article class="bg-white rounded-xl shadow-md p-6 hover:shadow-xl transition-shadow duration-300 cursor-pointer">
              <h3 class="text-xl font-semibold text-blue-600 mb-3">{titulo}</h3>
              <p class="text-gray-600 text-sm">{descripcion}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</div>
