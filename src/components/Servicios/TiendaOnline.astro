---
import PageHero from "../../components/PageHero.astro";
---

<PageHero
  label="Servicio"
  title='Tiendas <span class="gt">Online</span>'
  description="E-commerce modernos y seguros para mostrar y vender tus productos las 24 horas, con panel de administración intuitivo."
  accentColor="#a855f7"
/>

<!-- Intro -->
<section class="service-intro">
  <div class="service-intro-inner">
    <div class="service-intro-text">
      <p>
        Desarrollamos tiendas online completas con catálogo de productos,
        carrito de compras y panel de administración. Soluciones a medida que
        permiten a nuestros clientes exhibir y vender sus productos las 24 horas
        del día, con diseño atractivo y herramientas intuitivas para gestionar
        el negocio.
      </p>
      <a
        href="/contacto"
        class="btn-primary"
        style="width: fit-content; margin-top: 1rem;"
      >
        Contactarnos →
      </a>
    </div>
    <div class="service-intro-img">
      <img src="/servicios/tiendaOnline.png" alt="Tienda Online" />
    </div>
  </div>
</section>

<!-- Features -->
<section class="features-section">
  <div class="features-inner">
    <span class="section-label">¿Qué incluye?</span>
    <h2 class="features-title">Funcionalidades de tu tienda</h2>
    <div class="features-grid">
      {
        [
          {
            icon: "🛒",
            title: "Carrito de compras",
            desc: "Experiencia de compra fluida con carrito y checkout optimizado.",
          },
          {
            icon: "📦",
            title: "Catálogo de productos",
            desc: "Gestión de productos, variantes, imágenes y stock.",
          },
          {
            icon: "⚙️",
            title: "Panel de administración",
            desc: "Controla pedidos, clientes y productos desde un dashboard.",
          },
          {
            icon: "💳",
            title: "Pagos integrados",
            desc: "Integración con pasarelas de pago locales e internacionales.",
          },
          {
            icon: "📱",
            title: "Diseño responsivo",
            desc: "Optimizado para compras desde cualquier dispositivo.",
          },
          {
            icon: "📊",
            title: "Reportes y estadísticas",
            desc: "Visualiza ventas, clientes y productos más vendidos.",
          },
        ].map((item) => (
          <div class="feature-card">
            <span class="feature-icon">{item.icon}</span>
            <h3 class="feature-title">{item.title}</h3>
            <p class="feature-desc">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-intro {
    background: var(--color-bg-2);
    padding: 4rem 1.5rem;
  }
  .service-intro-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .service-intro-inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  .service-intro-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .service-intro-img img {
    width: 100%;
    border-radius: 16px;
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  }

  .features-section {
    background: var(--color-bg);
    padding: 4rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }
  .features-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .features-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #fff;
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .feature-card {
    padding: 1.5rem;
    background: rgba(10, 22, 40, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }
  .feature-card:hover {
    border-color: rgba(168, 85, 247, 0.3);
    transform: translateY(-3px);
  }
  .feature-icon {
    font-size: 1.75rem;
  }
  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }
  .feature-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
