---
import PageHero from "../../components/PageHero.astro";
---

<PageHero
  label="Servicio"
  title='Desarrollo de <span class="gt">Apps Móviles</span>'
  description="Aplicaciones Android personalizadas con React Native para resolver las necesidades de tu negocio o emprendimiento."
  accentColor="#22c55e"
/>

<section class="service-intro">
  <div class="service-intro-inner">
    <div class="service-intro-text">
      <p>
        Creamos aplicaciones móviles personalizadas utilizando <strong
          style="color: #22c55e;">React Native</strong
        >, la tecnología que nos permite desarrollar apps nativas para Android
        con un solo código base. Ideal para negocios que necesitan presencia
        móvil con integración a redes sociales y WhatsApp.
      </p>
      <a
        href="/contacto"
        class="btn-primary"
        style="width: fit-content; margin-top: 1rem; background: linear-gradient(135deg, #22c55e, #16a34a);"
      >
        Contactarnos →
      </a>
    </div>
    <div class="service-intro-img">
      <img src="/servicios/desarollomovil.png" alt="Desarrollo Móvil" />
    </div>
  </div>
</section>

<section class="features-section">
  <div class="features-inner">
    <span class="section-label" style="color: #22c55e;">¿Qué obtienes?</span>
    <h2 class="features-title">Características de la app</h2>
    <div class="features-grid">
      {
        [
          {
            icon: "📱",
            title: "Android nativo",
            desc: "Apps compiladas nativamente para mejor rendimiento.",
          },
          {
            icon: "🔗",
            title: "Integración social",
            desc: "Conexión con Instagram, Facebook, WhatsApp y más.",
          },
          {
            icon: "🗺️",
            title: "Mapas y ubicación",
            desc: "Integración de Google Maps y servicios de geolocalización.",
          },
          {
            icon: "🔔",
            title: "Notificaciones push",
            desc: "Mantén a tus usuarios al día con alertas en tiempo real.",
          },
          {
            icon: "🎨",
            title: "Diseño adaptable",
            desc: "UI moderna y funcional optimizada para pantallas móviles.",
          },
          {
            icon: "🔄",
            title: "Actualizaciones",
            desc: "Mantenimiento y actualizaciones del código incluidas en el contrato.",
          },
        ].map((item) => (
          <div
            class="feature-card"
            style="--accent-hover: rgba(34,197,94,0.2);"
          >
            <span class="feature-icon">{item.icon}</span>
            <h3 class="feature-title">{item.title}</h3>
            <p class="feature-desc">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-intro {
    background: var(--color-bg-2);
    padding: 4rem 1.5rem;
  }
  .service-intro-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .service-intro-inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  .service-intro-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .service-intro-img img {
    width: 100%;
    border-radius: 16px;
    border: 1px solid rgba(34, 197, 94, 0.2);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  }

  .features-section {
    background: var(--color-bg);
    padding: 4rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }
  .features-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .features-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #fff;
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .feature-card {
    padding: 1.5rem;
    background: rgba(10, 22, 40, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }
  .feature-card:hover {
    border-color: rgba(34, 197, 94, 0.3);
    transform: translateY(-3px);
  }
  .feature-icon {
    font-size: 1.75rem;
  }
  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }
  .feature-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
