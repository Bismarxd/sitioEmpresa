<div class="relative min-h-screen">
  <!-- Fondo -->
  <div class="absolute inset-0 bg-white dark:bg-gray-950 overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-950"
    >
    </div>
    <div class="absolute inset-0 opacity-20 dark:opacity-10">
      <svg width="100%" height="100%">
        <pattern
          id="data-flow-pattern"
          x="0"
          y="0"
          width="200"
          height="200"
          patternUnits="userSpaceOnUse"
        >
          <path
            d="M0 100 Q50 50, 100 100 T200 100"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            class="text-blue-400 dark:text-blue-600"></path>
          <path
            d="M0 120 Q50 70, 100 120 T200 120"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            class="text-indigo-400 dark:text-indigo-600"></path>
          <path
            d="M0 140 Q50 90, 100 140 T200 140"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            class="text-purple-400 dark:text-purple-600"></path>
          <path
            d="M0 80 Q50 30, 100 80 T200 80"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            class="text-sky-400 dark:text-sky-600"></path>
          <path
            d="M0 60 Q50 10, 100 60 T200 60"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            class="text-cyan-400 dark:text-cyan-600"></path>
        </pattern>
        <rect width="100%" height="100%" fill="url(#data-flow-pattern)"></rect>
      </svg>
    </div>
  </div>
  <!-- Contenido -->
  <div class="relative p-6 text-white">
    <div class="m-4 p-4 text-center">
      <h2 class="text-3xl font-bold">
        Tecnologías que usamos para el Desarrollo
      </h2>
    </div>

    <div>
      <!-- Frontend -->
      <div>
        <div class="text-center m-4">
          <h3 class="text-2xl">Frontend</h3>
        </div>

        <div
          class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 gap-6 justify-items-center"
        >
          <!-- React -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://upload.wikimedia.org/wikipedia/commons/a/a7/React-icon.svg"
              alt="React"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">React</p>
          </div>

          <!-- Astro -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://www.svgrepo.com/show/373446/astro.svg"
              alt="Astro"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">Astro</p>
          </div>

          <!-- Vue -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://upload.wikimedia.org/wikipedia/commons/9/95/Vue.js_Logo_2.svg"
              alt="Vue"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">Vue</p>
          </div>

          <!-- JavaScript -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://upload.wikimedia.org/wikipedia/commons/6/6a/JavaScript-logo.png"
              alt="JavaScript"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">JavaScript</p>
          </div>

          <!-- Tailwind CSS -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://upload.wikimedia.org/wikipedia/commons/d/d5/Tailwind_CSS_Logo.svg"
              alt="Tailwind CSS"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">Tailwind CSS</p>
          </div>
        </div>
      </div>
      <!-- Backend -->
      <div>
        <div class="text-center m-4">
          <h3 class="text-2xl">Backend</h3>
        </div>

        <div
          class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 gap-6 justify-items-center"
        >
          <!-- Node.js -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg"
              alt="Node.js"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">Node.js</p>
          </div>

          <!-- MySQL -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://upload.wikimedia.org/wikipedia/en/d/dd/MySQL_logo.svg"
              alt="MySQL"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">MySQL</p>
          </div>

          <!-- PHP -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://upload.wikimedia.org/wikipedia/commons/2/27/PHP-logo.svg"
              alt="PHP"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">PHP</p>
          </div>

          <!-- Express.js -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://upload.wikimedia.org/wikipedia/commons/6/64/Expressjs.png"
              alt="Express.js"
              class="w-16 h-16 object-contain"
            />
            <p class="mt-2 text-neutral-500 font-semibold">Express</p>
          </div>

          <!-- MongoDB -->
          <div
            class="bg-white rounded-lg shadow-lg p-4 flex flex-col items-center w-28"
          >
            <img
              src="https://upload.wikimedia.org/wikipedia/commons/9/93/MongoDB_Logo.svg"
              alt="MongoDB"
              class="w-16 h-16"
            />
            <p class="mt-2 text-neutral-500 font-semibold">MongoDB</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
