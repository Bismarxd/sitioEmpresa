---
import PageHero from "../../components/PageHero.astro";
---

<PageHero
  label="Servicio"
  title='Desarrollo Web <span class="gt">a Medida</span>'
  description="Sitios web modernos, rápidos y adaptables. Desde páginas corporativas hasta tiendas en línea, diseño y funcionalidad en un solo paquete."
/>

<!-- Hero visual + intro -->
<section class="service-intro">
  <div class="service-intro-inner">
    <div class="service-intro-text">
      <p>
        Dedicados a crear sitios web modernos, rápidos y adaptables a cualquier
        dispositivo. Ya sea una página corporativa o una tienda en línea,
        desarrollamos soluciones a medida que combinan diseño atractivo,
        funcionalidad y optimización para buscadores.
      </p>
      <a
        href="/contacto"
        class="btn-primary"
        style="width: fit-content; margin-top: 1rem;"
      >
        Contactarnos
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
    <div class="service-intro-img">
      <img src="/servicios/desarolloweb1.png" alt="Desarrollo Web" />
    </div>
  </div>
</section>

<!-- Tech stack -->
<section class="tech-section">
  <div class="tech-inner">
    <div class="tech-header">
      <span class="section-label">Stack tecnológico</span>
      <h2 class="tech-title">Tecnologías que usamos</h2>
    </div>

    <div class="tech-group">
      <h3 class="tech-group-title">Frontend</h3>
      <div class="tech-grid">
        {
          [
            {
              name: "React",
              src: "https://upload.wikimedia.org/wikipedia/commons/a/a7/React-icon.svg",
            },
            {
              name: "Astro",
              src: "https://www.svgrepo.com/show/373446/astro.svg",
            },
            {
              name: "Vue",
              src: "https://upload.wikimedia.org/wikipedia/commons/9/95/Vue.js_Logo_2.svg",
            },
            {
              name: "JavaScript",
              src: "https://upload.wikimedia.org/wikipedia/commons/6/6a/JavaScript-logo.png",
            },
            {
              name: "Tailwind",
              src: "https://upload.wikimedia.org/wikipedia/commons/d/d5/Tailwind_CSS_Logo.svg",
            },
          ].map((t) => (
            <div class="tech-chip">
              <img src={t.src} alt={t.name} class="tech-chip-icon" />
              <span>{t.name}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="tech-group">
      <h3 class="tech-group-title">Backend</h3>
      <div class="tech-grid">
        {
          [
            {
              name: "Node.js",
              src: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg",
            },
            {
              name: "MySQL",
              src: "https://upload.wikimedia.org/wikipedia/en/d/dd/MySQL_logo.svg",
            },
            {
              name: "PHP",
              src: "https://upload.wikimedia.org/wikipedia/commons/2/27/PHP-logo.svg",
            },
            {
              name: "Express",
              src: "https://upload.wikimedia.org/wikipedia/commons/6/64/Expressjs.png",
            },
            {
              name: "MongoDB",
              src: "https://upload.wikimedia.org/wikipedia/commons/9/93/MongoDB_Logo.svg",
            },
          ].map((t) => (
            <div class="tech-chip">
              <img src={t.src} alt={t.name} class="tech-chip-icon" />
              <span>{t.name}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<!-- What's included -->
<section class="includes-section">
  <div class="includes-inner">
    <span class="section-label">¿Qué incluye?</span>
    <h2 class="includes-title">Todo lo que necesitas</h2>
    <div class="includes-grid">
      {
        [
          {
            icon: "🎨",
            title: "Diseño personalizado",
            desc: "Interfaz moderna, responsiva y alineada con tu marca.",
          },
          {
            icon: "⚡",
            title: "Rendimiento optimizado",
            desc: "Carga rápida, SEO técnico y buenas prácticas.",
          },
          {
            icon: "📱",
            title: "100% Responsivo",
            desc: "Perfecto en móvil, tablet y escritorio.",
          },
          {
            icon: "🔒",
            title: "Seguridad",
            desc: "Medidas de seguridad y HTTPS configurado.",
          },
          {
            icon: "📊",
            title: "Panel de administración",
            desc: "Gestiona tu contenido sin saber programar.",
          },
          {
            icon: "🤝",
            title: "Soporte incluido",
            desc: "Acompañamiento post-entrega para cualquier ajuste.",
          },
        ].map((item) => (
          <div class="includes-card">
            <span class="includes-icon">{item.icon}</span>
            <h3 class="includes-card-title">{item.title}</h3>
            <p class="includes-card-desc">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ── Intro ── */
  .service-intro {
    background: var(--color-bg-2);
    padding: 4rem 1.5rem;
  }
  .service-intro-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .service-intro-inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  .service-intro-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .service-intro-img img {
    width: 100%;
    border-radius: 16px;
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  }

  /* ── Tech ── */
  .tech-section {
    background: var(--color-bg);
    padding: 4rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }
  .tech-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .tech-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tech-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #fff;
  }
  .tech-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .tech-group-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }
  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .tech-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(10, 22, 40, 0.7);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.875rem;
    color: var(--color-text);
    transition:
      border-color 0.2s,
      background 0.2s;
  }
  .tech-chip:hover {
    border-color: rgba(0, 212, 255, 0.35);
    background: rgba(0, 212, 255, 0.05);
  }
  .tech-chip-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  /* ── Includes ── */
  .includes-section {
    background: var(--color-bg-2);
    padding: 4rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }
  .includes-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .includes-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #fff;
  }
  .includes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .includes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .includes-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .includes-card {
    padding: 1.5rem;
    background: rgba(10, 22, 40, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }
  .includes-card:hover {
    border-color: rgba(0, 212, 255, 0.2);
    transform: translateY(-3px);
  }
  .includes-icon {
    font-size: 1.75rem;
  }
  .includes-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }
  .includes-card-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
