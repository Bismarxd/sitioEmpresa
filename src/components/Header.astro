---
import Navbar from "./Header/Navbar.astro";
import NavbarMovil from "./Header/NavbarMovil.astro";
import "../styles/global.css";
---

<header class="w-full bg-[#474747da] md:bg-[rgba(37,38,39,0.82)] text-white shadow-lg fixed z-50">
  <div
    class="container mx-auto px-2 flex flex-row justify-between items-center text-xl"
  >
    <img src="./logo/Logo.ico" class="w-32 text-white" />
    <!-- Navbar -->
    <Navbar />
    <!-- Navbar para móvil -->
    <NavbarMovil />
  </div>
</header>
