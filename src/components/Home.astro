---
import "@fontsource/edu-nsw-act-hand-pre";
import "@fontsource/edu-nsw-act-hand-pre/700.css";
import Social from "./Home/Social.astro";
---

<div class="relative min-h-screen xl:p-10">
  <!-- Fondo -->
  <div class="absolute inset-0 bg-gray-900 overflow-hidden">
    <div
      class="absolute inset-0 bg-gradient-to-br from-black via-gray-900 to-black"
    >
    </div>
    <div class="absolute -inset-[10%] opacity-50">
      <div
        class="absolute top-1/3 left-1/3 w-[40%] aspect-square rounded-full bg-gradient-to-r from-cyan-500 to-blue-500 blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-1/3 right-1/3 w-[40%] aspect-square rounded-full bg-gradient-to-r from-fuchsia-500 to-pink-500 blur-3xl"
      >
      </div>
    </div>
    <div class="absolute inset-0">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80%] h-[1px] bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-70"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[80%] w-[1px] bg-gradient-to-b from-transparent via-fuchsia-400 to-transparent opacity-70"
      >
      </div>
    </div>
  </div>
  <!-- Contenido -->
  <div
    class="relative md:py-0 md:h-screen pt-16 bg-cover bg-center bg-no-repeat text-white z-30"
  >
    <div class="absolute inset-0 z-0"></div>

    <div class="md:flex flex-wrap-reverse md:flex-row-reverse h-full">
      <div class="flex justify-center items-center md:h-screen z-20 mt-20">
        <img
          src="/Inicio/codigo.jpg"
          alt="Interfaz de Linear"
          class="w-full sm:w-[90%] md:w-[70%] max-w-5xl rounded-md sm:rounded-lg md:rounded-xl shadow-2xl
           transform rotate-0 sm:-rotate-3 md:-rotate-[8deg] hover:rotate-0 transition-transform duration-700 ease-out z-10"
        />
      </div>
      <div
        class="md:flex-1 flex flex-col justify-center items-center p-2 mt-10 lg:mt-20"
      >
        <div class="flex gap-3 mt-10 lg:mt-14">
          <div class="hidden md:flex mt-3">
            <Social />
          </div>
          <div class="ml-5">
            <h1
              class="my-font text-5xl font-bold text-center animate-pulse font-serif mb-5"
            >
              BISDEV SOFT
            </h1>
            <div class="text-center">
              <span id="typewriter" class="my-font text-xl mt-4 h-6 text-center"
              ></span>
            </div>

            <p class="m-5 font-semibold p-4">
              Desarollo de software web, dedicada al crecimiento de tu empresa o
              negocio.
            </p>
            <div class="flex justify-center">
              <button
                class="flex items-center gap-2 px-6 py-2 bg-gradient-to-r from-[#005377] to-[#003952] text-white rounded-full font-serif text-lg shadow-lg hover:scale-105 transition-transform duration-300 mt-7"
              >
                Contáctanos...
                <span class="animate-bounce">👉</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .my-font {
    font-family: "Edu NSW ACT Hand Pre", cursive;
  }

  #typewriter::after {
    content: "|";
    animation: blink 0.7s infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  const words = [
    "Desarrollo Web",
    "Desarollo Movil",
    "Paginas Web",
    "Diseño UX/UI",
  ];
  const typewriter: any = document.getElementById("typewriter");

  let wordIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function type() {
    const currentWord = words[wordIndex];
    let displayedText = currentWord.substring(0, charIndex);

    typewriter.textContent = displayedText;

    let typingSpeed = 100;

    if (isDeleting) {
      typingSpeed = 50;
      charIndex--;
    } else {
      charIndex++;
    }

    if (!isDeleting && charIndex === currentWord.length + 1) {
      typingSpeed = 3000; // Pausa antes de borrar
      isDeleting = true;
    }

    if (isDeleting && charIndex === 0) {
      isDeleting = false;
      wordIndex = (wordIndex + 1) % words.length;
      typingSpeed = 700; // Pausa antes de empezar a escribir nueva palabra
    }

    setTimeout(type, typingSpeed);
  }

  type();
</script>
