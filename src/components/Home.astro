---
import Social from "./Home/Social.astro";
---

<!-- Hero Section -->
<section class="hero-section">
  <!-- Animated background -->
  <div class="hero-bg">
    <div class="orb orb-cyan"></div>
    <div class="orb orb-purple"></div>
    <div class="grid-overlay"></div>
  </div>

  <!-- Content -->
  <div class="hero-content">
    <!-- Text column -->
    <div class="hero-text">
      <!-- Badge -->
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Soluciones digitales a medida
      </div>

      <!-- Heading -->
      <h1 class="hero-title">
        BISDEV
        <span class="hero-title-accent">SOFT</span>
      </h1>

      <!-- Typewriter-->
      <p class="hero-subtitle">
        <span id="typewriter"></span>
      </p>

      <!-- Description -->
      <p class="hero-description">
        Desarrollamos software web y móvil para impulsar el crecimiento de tu
        empresa o negocio con tecnología moderna.
      </p>

      <!-- CTA Buttons -->
      <div class="hero-ctas">
        <a href="/contacto" class="btn-primary">
          Iniciar proyecto
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
        <a href="/projectos" class="btn-outline"> Ver proyectos </a>
      </div>

      <!-- Stats -->
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">10<span class="stat-plus">+</span></span>
          <span class="stat-label">Proyectos</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">1<span class="stat-plus">+</span></span>
          <span class="stat-label">Años</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">100<span class="stat-plus">%</span></span>
          <span class="stat-label">Satisfacción</span>
        </div>
      </div>
    </div>

    <!-- Visual column -->
    <div class="hero-visual">
      <div class="hero-img-wrapper">
        <div class="hero-img-glow"></div>
        <img
          src="/Inicio/codigo.jpg"
          alt="Código de desarrollo de software"
          class="hero-img"
          loading="eager"
        />
        <!-- Floating badges -->
        <div class="floating-badge badge-tl">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg
          >
          React & Astro
        </div>
        <div class="floating-badge badge-br">
          <span class="status-dot"></span>
          En línea
        </div>
      </div>

      <!-- Social links (desktop only) -->
      <div class="hero-social">
        <Social />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  /* ── Section ── */
  .hero-section {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-top: 64px; /* header height */
  }

  /* ── Background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    background: var(--color-bg);
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.45;
    animation: float 8s ease-in-out infinite;
  }

  .orb-cyan {
    width: 55%;
    aspect-ratio: 1;
    top: -15%;
    right: -10%;
    background: radial-gradient(circle, #00d4ff44, #0099cc22, transparent 70%);
    animation-duration: 10s;
  }

  .orb-purple {
    width: 45%;
    aspect-ratio: 1;
    bottom: -20%;
    left: -5%;
    background: radial-gradient(circle, #a855f744, #7c3aed22, transparent 70%);
    animation-duration: 13s;
    animation-delay: -4s;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 212, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 255, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      black 40%,
      transparent 100%
    );
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr 1fr;
      padding: 3rem 2rem;
    }
  }

  /* ── Text ── */
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: rgba(0, 212, 255, 0.08);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-cyan);
    letter-spacing: 0.04em;
    width: fit-content;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-cyan);
    box-shadow: 0 0 8px var(--color-cyan);
    animation: glow-pulse 2s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2.8rem, 6vw + 1rem, 5rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .hero-title-accent {
    background: linear-gradient(135deg, var(--color-cyan), var(--color-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-cyan);
    min-height: 1.6em;
    letter-spacing: 0.02em;
  }

  .hero-subtitle::after {
    content: "|";
    animation: blink 0.7s infinite;
    color: var(--color-cyan);
    margin-left: 2px;
  }

  .hero-description {
    max-width: 500px;
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Stats ── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .stat-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
  }

  .stat-plus {
    color: var(--color-cyan);
    font-size: 1.1rem;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(0, 212, 255, 0.15);
    flex-shrink: 0;
  }

  /* ── Visual ── */
  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-img-wrapper {
    position: relative;
    width: 100%;
    max-width: 520px;
    animation: float 7s ease-in-out infinite;
  }

  .hero-img-glow {
    position: absolute;
    inset: -2px;
    border-radius: 20px;
    background: linear-gradient(
      135deg,
      rgba(0, 212, 255, 0.3),
      rgba(168, 85, 247, 0.3)
    );
    filter: blur(20px);
    z-index: -1;
  }

  .hero-img {
    width: 100%;
    border-radius: 18px;
    border: 1px solid rgba(0, 212, 255, 0.2);
    display: block;
    object-fit: cover;
    aspect-ratio: 16/10;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
  }

  /* Floating badges over image */
  .floating-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    background: rgba(5, 11, 24, 0.9);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .badge-tl {
    top: -16px;
    left: 16px;
    color: var(--color-cyan);
  }

  .badge-br {
    bottom: -14px;
    right: 16px;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 6px #22c55e;
    animation: glow-pulse 2s ease-in-out infinite;
  }

  /* Social */
  .hero-social {
    display: none;
  }

  @media (min-width: 1024px) {
    .hero-social {
      display: flex;
    }
  }

  /* ── Scroll indicator ── */
  .scroll-indicator {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 10;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-cyan), transparent);
    animation: scroll-line 2s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(1);
    }
    50% {
      opacity: 1;
      transform: scaleY(1.15);
    }
  }
</style>

<script>
  // Typewriter
  const words = [
    "Desarrollo Web",
    "Desarrollo Móvil",
    "Tiendas Online",
    "Diseño UX/UI",
  ];
  const el = document.getElementById("typewriter") as HTMLElement;

  let wi = 0;
  let ci = 0;
  let deleting = false;

  function type() {
    const word = words[wi];
    el.textContent = word.substring(0, ci);

    let speed = 95;

    if (deleting) {
      ci--;
      speed = 45;
    } else {
      ci++;
    }

    if (!deleting && ci === word.length + 1) {
      speed = 2500;
      deleting = true;
    }

    if (deleting && ci === 0) {
      deleting = false;
      wi = (wi + 1) % words.length;
      speed = 500;
    }

    setTimeout(type, speed);
  }

  type();
</script>
