---
const tarjetas = [
  {
    titulo: "Desarrollo Web A Medida",
    info: "Páginas personales, corporativas o institucionales con funcionalidades específicas y diseño personalizado.",
    features: [
      "Diseño Moderno y Responsivo",
      "Secciones Editables o Estáticas",
      "Portafolios, Blog, Landing Page",
    ],
    link: "/desarolloweb",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    color: "#00d4ff",
  },
  {
    titulo: "Tiendas Online",
    info: "E-commerce para empresas, negocios o emprendedores para mostrar y vender sus productos.",
    features: [
      "Catálogo de Productos",
      "Carrito de Compras",
      "Panel de Administración",
    ],
    link: "/tiendaonline",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`,
    color: "#a855f7",
  },
  {
    titulo: "Apps Móviles",
    info: "Aplicaciones móviles para Android enfocadas en resolver necesidades de tu negocio o emprendimiento.",
    features: [
      "Apps para Android",
      "Diseño Funcional y Adaptable",
      "Integración con RRSS y WhatsApp",
    ],
    link: "/desarollomovil",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    color: "#22c55e",
  },
  {
    titulo: "Mantenimiento y Soporte",
    info: "Nos encargamos de mantener tu sitio web actualizado, seguro y en funcionamiento continuo.",
    features: [
      "Actualización y Corrección de Errores",
      "Revisión Técnica Periódica",
      "Soporte Rápido",
    ],
    link: "/mantenimientosoporte",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    color: "#f59e0b",
  },
];
---

<!-- Desktop grid + mobile carousel -->
<div class="cards-grid">
  {tarjetas.map((tarjeta) => (
    <a href={tarjeta.link} class="service-card" style={`--card-color: ${tarjeta.color}`}>
      <!-- Icon -->
      <div class="card-icon" set:html={tarjeta.icon} />

      <!-- Content -->
      <div class="card-content">
        <h3 class="card-title">{tarjeta.titulo}</h3>
        <p class="card-info">{tarjeta.info}</p>

        <ul class="card-features">
          {tarjeta.features.map((f) => (
            <li class="card-feature">
              <svg class="feature-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
      </div>

      <!-- Footer -->
      <div class="card-footer">
        <span class="card-cta">
          Ver más
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      </div>

      <!-- Glow border on hover -->
      <div class="card-glow-border"></div>
    </a>
  ))}
</div>

<style>
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .cards-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ── Card ── */
  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(10, 22, 40, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 18px;
    text-decoration: none;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
    backdrop-filter: blur(10px);
  }

  .service-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--card-color, #00d4ff) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .service-card:hover {
    transform: translateY(-6px);
    border-color: var(--card-color, #00d4ff);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4),
                0 0 0 1px var(--card-color),
                0 0 40px -10px var(--card-color);
  }

  .service-card:hover::before {
    opacity: 0.04;
  }

  /* ── Icon ── */
  .card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--card-color, #00d4ff);
    flex-shrink: 0;
    transition: background 0.3s, border-color 0.3s;
  }

  .service-card:hover .card-icon {
    background: rgba(255,255,255,0.08);
    border-color: var(--card-color);
  }

  /* ── Content ── */
  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }

  .card-info {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  /* ── Features ── */
  .card-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .card-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: rgba(200, 214, 229, 0.8);
    line-height: 1.4;
  }

  .feature-check {
    color: var(--card-color, #00d4ff);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── Footer ── */
  .card-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--card-color, #00d4ff);
    transition: gap 0.2s ease;
  }

  .service-card:hover .card-cta {
    gap: 0.625rem;
  }
</style>
