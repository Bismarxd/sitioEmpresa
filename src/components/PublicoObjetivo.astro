---
import PublicoObjetivoCard from "./Home/PublicoObjetivoCard.astro";
---

<section class="audience-section">
  <div class="audience-bg">
    <div class="audience-orb"></div>
  </div>

  <div class="audience-inner">
    <!-- Header -->
    <div class="audience-header">
      <span class="section-label">¿Para quién?</span>
      <h2 class="audience-title">
        Nuestro<br />
        <span class="gradient-text">mercado objetivo</span>
      </h2>
      <p class="audience-description">
        Trabajamos con negocios y emprendedores de todos los tamaños que quieren
        crecer en el mundo digital.
      </p>
    </div>

    <!-- Cards -->
    <PublicoObjetivoCard />
  </div>
</section>

<style>
  .audience-section {
    position: relative;
    padding: 6rem 1.5rem;
    overflow: hidden;
    background: var(--color-bg);
  }

  .audience-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .audience-orb {
    position: absolute;
    width: 45%;
    aspect-ratio: 1;
    bottom: -15%;
    right: -10%;
    background: radial-gradient(
      circle,
      rgba(0, 212, 255, 0.1),
      transparent 70%
    );
    filter: blur(60px);
  }

  .audience-inner {
    position: relative;
    z-index: 10;
    max-width: 1280px;
    margin: 0 auto;
  }

  .audience-header {
    max-width: 520px;
    margin-bottom: 3rem;
  }

  .audience-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .audience-description {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
</style>
