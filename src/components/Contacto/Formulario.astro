---
import PageHero from "../../components/PageHero.astro";
---

<PageHero
  label="Contacto"
  title='Hablemos de tu <span class="gt">Proyecto</span>'
  description="Cuéntanos sobre tu idea y nos pondremos en contacto contigo lo antes posible para hacerla realidad."
  accentColor="#ec4899"
/>

<section class="contact-section">
  <div class="contact-inner">
    <div class="contact-grid">
      <!-- Info col -->
      <div class="contact-info">
        <h2 class="info-title">Información de Contacto</h2>
        <p class="info-desc">
          Estamos listos para transformar tus ideas en soluciones digitales.
          Envíanos un mensaje o comunícate directamente por nuestros canales.
        </p>

        <div class="info-items">
          <div class="info-item">
            <div class="info-icon">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div class="info-text">
              <span class="info-label">Email</span>
              <a href="mailto:bismarckmaytatintaya@gmail.com" class="info-value"
                >bismarckmaytatintaya@gmail.com</a
              >
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div class="info-text">
              <span class="info-label">Ubicación</span>
              <span class="info-value">La Paz, Bolivia</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Form col -->
      <div class="contact-form-container">
        <div class="form-wrapper">
          <h3 class="form-title">Envíanos un mensaje</h3>
          <form
            class="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
          >
            <!-- Web3Forms Access Key (Reemplaza este valor con tu access key cuando la tengas) -->
            <input
              type="hidden"
              name="access_key"
              value="58a7e034-9f77-4a98-b1df-9434310ea9bd"
            />

            <!-- Configuración para mostrar la validación del bot -->
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display: none;"
            />

            <!-- Redirección (Opcional) -->
            <!-- <input type="hidden" name="redirect" value="https://tupagina.com/gracias" /> -->

            <div class="input-group">
              <label for="name">Nombre completo</label>
              <input
                type="text"
                name="name"
                id="name"
                placeholder="Ej. Juan Pérez"
                class="form-input"
                required
              />
            </div>

            <div class="input-group">
              <label for="email">Correo electrónico</label>
              <input
                type="email"
                name="email"
                id="email"
                placeholder="tucorreo@ejemplo.com"
                class="form-input"
                required
              />
            </div>

            <div class="input-group">
              <label for="message">Mensaje</label>
              <textarea
                name="message"
                id="message"
                rows="5"
                placeholder="Cuéntanos sobre tu proyecto..."
                class="form-textarea"
                required></textarea>
            </div>

            <button
              type="submit"
              class="btn-primary"
              style="width: 100%; justify-content: center; margin-top: 1rem; background: linear-gradient(135deg, #ec4899, #be185d);"
            >
              Enviar mensaje
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-bg);
    padding: 5rem 1.5rem;
  }
  .contact-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 5fr 7fr;
    }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .info-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
  }
  .info-desc {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }
  .info-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(236, 72, 153, 0.1);
    color: #ec4899;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .info-icon svg {
    width: 24px;
    height: 24px;
  }
  .info-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .info-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .info-value {
    font-size: 1.1rem;
    color: #fff;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }
  a.info-value:hover {
    color: #ec4899;
  }

  /* Form */
  .contact-form-container {
    perspective: 1000px;
  }
  .form-wrapper {
    background: rgba(10, 22, 40, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .form-wrapper {
      padding: 3rem;
    }
  }
  .form-wrapper::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #ec4899, #be185d);
  }
  .form-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 2rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .input-group label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .form-input,
  .form-textarea {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem;
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    transition:
      border-color 0.2s,
      background 0.2s;
  }
  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #ec4899;
    background: rgba(255, 255, 255, 0.05);
  }
  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }
</style>
