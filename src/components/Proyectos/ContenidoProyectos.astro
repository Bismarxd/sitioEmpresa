---
import PageHero from "../../components/PageHero.astro";

const proyectos = [
  {
    titulo: "E-commerce Completo",
    descripcion:
      "Tienda online con panel de clientes y administradores. Gestión de productos, pedidos y usuarios con una experiencia fluida.",
    imagen: "/projectos/ProjectEcommerce.png",
    boton: "Visitar Proyecto",
    tags: ["React", "Node.js", "Stripe"],
    color: "#3b82f6",
  },
  {
    titulo: "Seguimiento Clínico",
    descripcion:
      "Sistema web para clínicas veterinarias que gestiona el historial clínico de mascotas, seguimiento de consultas, tratamientos y vacunas.",
    imagen: "/projectos/ProjectMonitoreoVetrinaria.png",
    boton: "Visitar Proyecto",
    tags: ["Astro", "Tailwind", "Firebase"],
    color: "#10b981",
  },
  {
    titulo: "Gestión de Titulados",
    descripcion:
      "Software institucional de la UMSA para facilitar el registro y seguimiento de las actividades profesionales de diplomados y egresados.",
    imagen: "/projectos/ProjectSeguimiento.png",
    boton: "Visitar Proyecto",
    tags: ["Vue", "PHP", "MySQL"],
    color: "#8b5cf6",
  },
];
---

<PageHero
  label="Portafolio"
  title='Proyectos <span class="gt">Destacados</span>'
  description="Una selección de trabajos recientes que demuestran nuestra capacidad para crear soluciones que resuelven problemas del mundo real."
  accentColor="#6366f1"
/>

<section class="projects-section">
  <div class="projects-inner">
    <div class="projects-list">
      {
        proyectos.map((proyecto, index) => (
          <article
            class={`project-card ${index % 2 !== 0 ? "project-card-reverse" : ""}`}
            style={`--proj-accent: ${proyecto.color}`}
          >
            <div class="project-image-cont">
              <div class="project-image-wrapper">
                <img
                  src={proyecto.imagen}
                  alt={proyecto.titulo}
                  class="project-img"
                />
                <div class="project-overlay" />
              </div>
            </div>

            <div class="project-content">
              <h3 class="project-title">{proyecto.titulo}</h3>
              <p class="project-desc">{proyecto.descripcion}</p>

              <div class="project-tags">
                {proyecto.tags.map((tag) => (
                  <span class="proj-tag">{tag}</span>
                ))}
              </div>

              <a href="#" class="project-link">
                <span>{proyecto.boton}</span>
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    background: var(--color-bg);
    padding: 5rem 1.5rem;
  }
  .projects-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .project-card {
      grid-template-columns: 1.2fr 1fr;
      gap: 4rem;
    }
    .project-card-reverse {
      grid-template-columns: 1fr 1.2fr;
    }
    .project-card-reverse .project-image-cont {
      order: 2;
    }
    .project-card-reverse .project-content {
      order: 1;
    }
  }

  .project-image-cont {
    position: relative;
    border-radius: 24px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent);
  }

  .project-image-wrapper {
    position: relative;
    border-radius: 23px;
    overflow: hidden;
    aspect-ratio: 16/10;
    background: #000;
  }
  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .project-card:hover .project-img {
    transform: scale(1.05);
  }
  .project-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.4), transparent);
    pointer-events: none;
  }

  .project-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .project-title {
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
  }
  .project-desc {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .proj-tag {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--proj-accent);
    background: color-mix(in srgb, var(--proj-accent) 15%, transparent);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--proj-accent) 30%, transparent);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    text-decoration: none;
    margin-top: 1rem;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    width: fit-content;
  }
  .project-card:hover .project-link {
    border-bottom-color: var(--proj-accent);
    color: var(--proj-accent);
  }
  .project-link svg {
    transition: transform 0.2s;
  }
  .project-card:hover .project-link svg {
    transform: translateX(4px);
  }
</style>
